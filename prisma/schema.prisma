generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLATFORM_ADMIN
  DEVOPS_ENGINEER
  PLATFORM_BSA
  RELEASE_MANAGER
  LEADERSHIP
  VIEWER
}

enum CalendarSource {
  INTERNAL
  OUTLOOK
}

enum WebexDeliveryStatus {
  NONE
  SKIPPED
  SENT
  FAILED
}

/// Recurring internal calendar template (Outlook rows never attach to a series).
enum SeriesRecurrence {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      UserRole @default(VIEWER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditEvents AuditLog[] @relation("ActorAuditLogs")
}

model AuditLog {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  correlationId String?
  actorUserId     String?
  action          String
  resourceType    String?
  resourceId      String?
  payload         Json?
  metadata        Json?
  actor           User?     @relation("ActorAuditLogs", fields: [actorUserId], references: [id])

  @@index([createdAt(sort: Desc)])
  @@index([actorUserId])
  @@index([correlationId])
}

model Team {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  calendarEvents CalendarEvent[]
  series         CalendarEventSeries[]
}

/// Definition for repeating OpsPilot events (materialized rows in CalendarEvent).
model CalendarEventSeries {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Restrict)

  title       String
  description String?
  location    String?

  timeZone String
  allDay   Boolean @default(false)

  notifyWebex Boolean @default(false)

  recurrence        SeriesRecurrence
  recurrenceEndsAt  DateTime?
  anchorStartsAt    DateTime
  durationMinutes   Int

  active              Boolean @default(true)
  lastExpandedUntilUtc DateTime?

  events CalendarEvent[]

  @@index([teamId])
  @@index([active])
}

model CalendarEvent {
  id          String               @id @default(cuid())
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  title       String
  description String?
  location    String?
  startsAt    DateTime
  endsAt      DateTime
  timeZone    String               @default("UTC")
  allDay      Boolean              @default(false)
  source      CalendarSource       @default(INTERNAL)
  outlookEventId String?         @unique
  outlookICalUid String?
  outlookWebLink String?

  notifyWebex     Boolean             @default(false)
  webexDelivery   WebexDeliveryStatus @default(NONE)
  webexHttpStatus Int?
  webexDetail     String?

  teamId String?
  team   Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  seriesId String?
  series   CalendarEventSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)

  @@index([startsAt(sort: Asc)])
  @@index([teamId])
  @@index([seriesId])
  @@unique([seriesId, startsAt], map: "CalendarEvent_series_starts_unique")
}

model OAuthPkceState {
  state        String   @id
  codeVerifier String
  createdAt    DateTime @default(now())

  @@index([createdAt(sort: Asc)])
}

model OutlookCalendarCredential {
  id                    String    @id
  encryptedRefreshToken String?
  scope                 String?
  issuedAt              DateTime  @default(now())
  tenantIdUsed          String?
  azureAdUserObjectId   String?
  userPrincipalName     String?
  updatedAt             DateTime  @updatedAt
}
