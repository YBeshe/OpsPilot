generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PLATFORM_ADMIN
  DEVOPS_ENGINEER
  PLATFORM_BSA
  RELEASE_MANAGER
  LEADERSHIP
  VIEWER
}

enum CalendarSource {
  INTERNAL
  OUTLOOK
}

enum WebexDeliveryStatus {
  NONE
  SKIPPED
  SENT
  FAILED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      UserRole @default(VIEWER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditEvents AuditLog[] @relation("ActorAuditLogs")
}

model AuditLog {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  correlationId String?
  actorUserId     String?
  action          String
  resourceType    String?
  resourceId      String?
  payload         Json?
  metadata        Json?
  actor           User?     @relation("ActorAuditLogs", fields: [actorUserId], references: [id])

  @@index([createdAt(sort: Desc)])
  @@index([actorUserId])
  @@index([correlationId])
}

model CalendarEvent {
  id         String               @id @default(cuid())
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  title      String
  description String?
  location   String?
  startsAt   DateTime
  endsAt     DateTime
  timeZone   String               @default("UTC")
  allDay     Boolean              @default(false)
  source     CalendarSource       @default(INTERNAL)
  outlookEventId String?         @unique
  outlookICalUid String?
  outlookWebLink String?

  notifyWebex     Boolean             @default(false)
  webexDelivery   WebexDeliveryStatus @default(NONE)
  webexHttpStatus Int?
  webexDetail     String?

  @@index([startsAt(sort: Asc)])
}

model OAuthPkceState {
  state        String   @id
  codeVerifier String
  createdAt    DateTime @default(now())

  @@index([createdAt(sort: Asc)])
}

model OutlookCalendarCredential {
  id                    String    @id
  encryptedRefreshToken String?
  scope                 String?
  issuedAt              DateTime  @default(now())
  tenantIdUsed          String?
  azureAdUserObjectId   String?
  userPrincipalName     String?
  updatedAt             DateTime  @updatedAt
}
