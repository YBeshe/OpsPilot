# Postgres (Docker Compose binds host port 5435 -> container 5432)
DATABASE_URL=postgresql://opspilot:opspilot@localhost:5435/opspilot?schema=public

# Public origin for redirects (omit trailing slash). Example below matches Next dev server.
APP_BASE_URL=http://localhost:3010

# 32-byte key as 64 hex chars — protects stored Microsoft refresh tokens at rest.
# openssl rand -hex 32
INTEGRATIONS_ENCRYPTION_KEY=

# Microsoft Entra (Outlook / Microsoft Graph). Register a web app with PKCE and
# redirect URI: {APP_BASE_URL}/api/v1/integrations/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# Tenant GUID or "common" for multi-tenant dev tenants
MICROSOFT_TENANT_ID=common
# Optional override if the redirect host differs from APP_BASE_URL
# MICROSOFT_REDIRECT_URI=http://localhost:3010/api/v1/integrations/microsoft/callback

# Cisco Webex bot (Messages API). Create a bot, add it to the target space/room.
WEBEX_BOT_TOKEN=
WEBEX_NOTIFICATION_ROOM_ID=

# Recurring internal events: POST /api/v1/calendar/recurrence/tick with
# Authorization: Bearer <secret> (e.g. nightly cron) to materialize future rows.
OPS_CRON_SECRET=
# How far ahead to expand series (UTC days from “now”); default 180.
OPS_RECURRENCE_HORIZON_DAYS=180
