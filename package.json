{
  "name": "opspilot",
  "version": "0.1.0",
  "private": true,
  "description": "OpsPilot — DevOps & Platform Automation Hub (greenfield scaffold)",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev -p 3010",
    "build": "prisma generate && next build",
    "start": "next start -p 3010",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:validate": "DATABASE_URL=${DATABASE_URL:-postgresql://opspilot:opspilot@127.0.0.1:5435/opspilot?schema=public} prisma validate",
    "db:migrate": "prisma migrate deploy",
    "db:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "docker:db": "docker compose up -d db",
    "docker:db:down": "docker compose down"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "next": "14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "eslintConfig": {
    "extends": "next/core-web-vitals"
  }
}
